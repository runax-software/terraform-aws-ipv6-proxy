nscache 65536
# AWS VPC resolver first (IPv4), then public IPv4, then IPv6.
nserver 169.254.169.253
nserver 1.1.1.1
nserver 8.8.8.8
nserver 2606:4700:4700::1111
nserver 2001:4860:4860::8888
timeouts 1 5 30 60 180 1800 15 60
setgid 65535
setuid 65535
rotate 10
flush
{% if proxy_user | length > 0 and proxy_pass | length > 0 %}
users {{ proxy_user }}:CL:{{ proxy_pass }}
auth strong
{% else %}
auth none
{% endif %}
allow *
{% for ip in proxy_ipv6_addresses %}
# {{ ip }}
socks -6 -p{{ proxy_socks_base_port | int + loop.index0 }} -i:: -e{{ ip }}
{% if proxy_ipv4_listen %}
socks -6 -p{{ proxy_v4_base_port | int + loop.index0 }} -i0.0.0.0 -e{{ ip }}
{% endif %}
{% endfor %}
